generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ARTISAN
  ADMIN
}

enum ArtisanStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  IN_PROCESS
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
  BOLETO
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
}

enum MessageType {
  TEXT
  IMAGE
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  artisanProfile  ArtisanProfile?
  orders          Order[]
  reviews         Review[]
  sentMessages    Message[]                @relation("SentMessages")
  conversations   ConversationParticipant[]
  addresses       Address[]
  passwordResets  PasswordResetToken[]
}

// ─── AUTH (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ADDRESS ──────────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String?
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── ARTISAN PROFILE ──────────────────────────────────────────────────────────

model ArtisanProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  storeName    String
  slug         String        @unique
  bio          String?
  story        String?
  bannerImage  String?
  logoImage    String?
  location     String?
  city         String?
  state        String?
  whatsapp     String?
  instagram    String?
  website      String?
  status       ArtisanStatus @default(PENDING)
  rejectedNote String?
  featured     Boolean       @default(false)
  rating       Float         @default(0)
  totalSales   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
  subscription Subscription?
  commissions  Commission[]
  withdrawals  Withdrawal[]
  reviews      Review[]
  categories   ArtisanCategory[]
}

// ─── CATEGORY ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  active      Boolean  @default(true)
  order       Int      @default(0)

  products          Product[]
  artisanCategories ArtisanCategory[]
}

model ArtisanCategory {
  artisanId  String
  categoryId String

  artisan  ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([artisanId, categoryId])
}

// ─── PRODUCT ──────────────────────────────────────────────────────────────────

model Product {
  id           String        @id @default(cuid())
  artisanId    String
  categoryId   String?
  name         String
  slug         String        @unique
  description  String?
  story        String?
  price        Float
  comparePrice Float?
  stock        Int           @default(0)
  sku          String?
  weight       Float?
  tags         String[]
  materials    String[]
  status       ProductStatus @default(DRAFT)
  featured     Boolean       @default(false)
  views        Int           @default(0)
  rating       Float         @default(0)
  salesCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artisan    ArtisanProfile   @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  category   Category?        @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
  reviews    Review[]
  highlights ProductHighlight[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── PRODUCT HIGHLIGHT (destaque pago) ────────────────────────────────────────

model ProductHighlight {
  id        String   @id @default(cuid())
  productId String
  startsAt  DateTime
  endsAt    DateTime
  pricePaid Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── ORDER ────────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  customerId   String
  addressId    String?
  status       OrderStatus @default(PENDING)
  subtotal     Float
  shippingCost Float       @default(0)
  discount     Float       @default(0)
  total        Float
  notes        String?
  trackingCode String?
  estimatedAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customer Address? @relation(fields: [addressId], references: [id])
  user     User     @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payment  Payment?
  reviews  Review[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  artisanId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id])
  commission Commission?
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Float
  asaasPaymentId   String?
  asaasPaymentLink String?
  pixQrCode        String?
  pixQrCodeBase64  String?
  boletoUrl        String?
  boletoBarcode    String?
  paidAt           DateTime?
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── COMMISSION ───────────────────────────────────────────────────────────────

model Commission {
  id          String    @id @default(cuid())
  artisanId   String
  orderItemId String    @unique
  saleAmount  Float
  rate        Float
  amount      Float
  paid        Boolean   @default(false)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  artisan   ArtisanProfile @relation(fields: [artisanId], references: [id])
  orderItem OrderItem      @relation(fields: [orderItemId], references: [id])
}

// ─── SUBSCRIPTION ─────────────────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  artisanId          String             @unique
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  asaasSubscriptionId String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)
}

// ─── WITHDRAWAL ───────────────────────────────────────────────────────────────

model Withdrawal {
  id          String           @id @default(cuid())
  artisanId   String
  amount      Float
  pixKey      String
  status      WithdrawalStatus @default(PENDING)
  notes       String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  artisan ArtisanProfile @relation(fields: [artisanId], references: [id])
}

// ─── REVIEW ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  artisanId String?
  orderId   String?
  rating    Int
  comment   String?
  reply     String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id])
  product Product?        @relation(fields: [productId], references: [id])
  artisan ArtisanProfile? @relation(fields: [artisanId], references: [id])
  order   Order?          @relation(fields: [orderId], references: [id])
}

// ─── CHAT ─────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(TEXT)
  readAt         DateTime?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
}

// ─── CONTACT MESSAGE ──────────────────────────────────────────────────────────

model ContactMessage {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  read       Boolean   @default(false)
  reply      String?
  repliedAt  DateTime?
  token      String    @unique @default(cuid())
  createdAt  DateTime  @default(now())
}
